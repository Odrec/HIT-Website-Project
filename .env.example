# HIT-Website Project Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://hit_user:hit_password@localhost:5432/hit_db"

# =============================================================================
# Redis Configuration
# =============================================================================
# Redis connection string for caching
REDIS_URL="redis://localhost:6379"

# =============================================================================
# NextAuth.js Configuration
# =============================================================================
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# Base URL of the application (used for redirects)
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# Application Configuration
# =============================================================================
# Environment (development, staging, production)
NODE_ENV="development"

# =============================================================================
# AI/LLM Configuration (for Study Navigator)
# =============================================================================
# You can use either OpenAI or Google Gemini for the AI navigator.
# If both are set, OpenAI takes priority.

# OpenAI Configuration (recommended)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Model options: gpt-4o, gpt-4o-mini (default), gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL="gpt-4o-mini"

# Google AI (Gemini) Configuration (alternative)
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=""
# Model options: gemini-1.5-pro, gemini-1.5-flash (default), gemini-1.0-pro
GOOGLE_AI_MODEL="gemini-1.5-flash"

# =============================================================================
# Optional: External Services
# =============================================================================
# Map service API key (if using Google Maps or similar)
# NEXT_PUBLIC_MAP_API_KEY=""

# File storage (if using cloud storage)
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_BUCKET=""
# S3_REGION=""

# =============================================================================
# Optional: Monitoring & Analytics
# =============================================================================
# Enable performance metric collection in non-development environments.
# In development this is always on. Set to "true" to enable in production.
# ENABLE_PERFORMANCE_MONITORING="false"

# Sentry DSN for error tracking
# SENTRY_DSN=""

# Analytics ID
# NEXT_PUBLIC_ANALYTICS_ID=""

# =============================================================================
# Email Notifications (SMTP via UOS Relay)
# =============================================================================
# No authentication needed — relay.rz.uni-osnabrueck.de accepts mail
# from within the university network without credentials.
# SMTP_HOST="relay.rz.uni-osnabrueck.de"
# SMTP_PORT="25"
# EMAIL_FROM="hit@zsb.os.de"
# EMAIL_TO="hit@zsb.os.de"

# =============================================================================
# Static HTML Export
# =============================================================================
# EXPORT_API_KEY=""
# EXPORT_OUTPUT_DIR=""

# =============================================================================
# Matomo Analytics (cookieless)
# =============================================================================
# NEXT_PUBLIC_MATOMO_URL=""
# NEXT_PUBLIC_MATOMO_SITE_ID=""

# =============================================================================
# Optional: Load Testing (scripts/load-test.ts)
# =============================================================================
# Target URL for load tests
# LOAD_TEST_URL="http://localhost:3000"
# Number of concurrent virtual users
# LOAD_TEST_CONCURRENT="50"
# Test duration in seconds
# LOAD_TEST_DURATION="30"
# Delay between requests per user (ms)
# LOAD_TEST_DELAY="500"
