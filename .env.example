# HIT-Website Project Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://hit_user:hit_password@localhost:5432/hit_db"

# =============================================================================
# Redis Configuration
# =============================================================================
# Redis connection string for caching
REDIS_URL="redis://localhost:6379"

# =============================================================================
# NextAuth.js Configuration
# =============================================================================
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# Canonical public base URL of the application. Used for auth redirects,
# email notification links, and schedule share links (QR/short link).
# In production set this to the public hostname (NOT the internal bind
# address), e.g. https://hit-website-virtuos-openstack.uni-osnabrueck.de
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# Application Configuration
# =============================================================================
# Environment (development, staging, production)
NODE_ENV="development"

# =============================================================================
# AI/LLM Configuration (for Study Navigator)
# =============================================================================
# Supports OpenAI, Google Gemini, or any OpenAI-compatible server (vLLM, Ollama, etc.).
# Priority: OPENAI_API_BASE_URL / OPENAI_API_KEY > GOOGLE_AI_API_KEY > fallback mode.

# OpenAI-compatible Configuration (works with OpenAI, vLLM, Ollama, etc.)
# For local LLMs (vLLM, Ollama): set OPENAI_API_BASE_URL instead/additionally.
# If the local server requires an API key, set OPENAI_API_KEY as well.
OPENAI_API_KEY=""
# Model options: gpt-4o, gpt-4o-mini (default), gpt-4-turbo, gpt-3.5-turbo
# For vLLM: use the model name as loaded (e.g., "meta-llama/Llama-3.1-8B-Instruct")
OPENAI_MODEL="gpt-4o-mini"
# Base URL override for local/self-hosted LLMs (vLLM, Ollama, etc.)
# Examples: http://localhost:8000/v1 (vLLM), http://localhost:11434/v1 (Ollama)
# When set, this takes priority over the default OpenAI endpoint.
# OPENAI_API_BASE_URL=""

# Google AI (Gemini) Configuration (alternative)
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=""
# Model options: gemini-1.5-pro, gemini-1.5-flash (default), gemini-1.0-pro
GOOGLE_AI_MODEL="gemini-1.5-flash"

# =============================================================================
# Google Maps Directions API
# =============================================================================
# Server-side only, for walking route calculation between campus buildings.
# Included in university Google Cloud contract.
# GOOGLE_MAPS_API_KEY=""

# =============================================================================
# Email Notifications (SMTP via UOS Relay)
# =============================================================================
# No authentication needed — relay.rz.uni-osnabrueck.de accepts mail
# from within the university network without credentials.
# SMTP_HOST="relay.rz.uni-osnabrueck.de"
# SMTP_PORT="25"
# EMAIL_FROM="hit@zsb.os.de"
# EMAIL_TO="hit@zsb.os.de"

# =============================================================================
# Public Contact Email
# =============================================================================
# Address shown in the public site footer ("Kontakt" column). Must be
# NEXT_PUBLIC_* so the value is available in the client-side bundle —
# otherwise server and client render different emails and React reports a
# hydration mismatch. Defaults to hit@zsb.os.de when unset.
# NEXT_PUBLIC_CONTACT_EMAIL="hit@zsb.os.de"

# =============================================================================
# Static HTML Export
# =============================================================================
# EXPORT_API_KEY=""

# =============================================================================
# Matomo Analytics (cookieless)
# =============================================================================
# NEXT_PUBLIC_MATOMO_URL=""
# NEXT_PUBLIC_MATOMO_SITE_ID=""

# =============================================================================
# Performance Monitoring
# =============================================================================
# Enable performance metric collection in non-development environments.
# In development this is always on. Set to "true" to enable in production.
# ENABLE_PERFORMANCE_MONITORING="false"

