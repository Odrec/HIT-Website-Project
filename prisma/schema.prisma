// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums
// =============================================================================

enum Institution {
  UNI
  HOCHSCHULE
  BOTH
}

enum EventType {
  VORTRAG
  LABORFUEHRUNG
  RUNDGANG
  WORKSHOP
  ONLINE
  VIDEO
  INFOSTAND
  SCHNUPPER
  INTERAKTION
  SONSTIGES
}

/// How the building/room for an event is captured on the form.
/// CONFIRMED -> Gebäude + Raum picked from the managed list.
/// WISH      -> Melder didn't know yet: they pick a campus area and
///              describe their room preferences in roomRequest.
enum LocationMode {
  CONFIRMED
  WISH
}

/// Wish-mode campus area when LocationMode = WISH.
enum CampusArea {
  WESTERBERG
  CAPRIVI
  INNENSTADT
}

enum EditionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum EventReviewStatus {
  DRAFT_FROM_ROLLOVER
  NEEDS_REVIEW
  PUBLISHED
}

enum UserRole {
  ADMIN
  ORGANIZER
  PUBLIC
}

enum Affiliation {
  UNI
  HOCHSCHULE
  BEIDE
  EXTERN
}

// =============================================================================
// Core Tables
// =============================================================================

/// Study program cluster (Studienfeld) for grouping related programs.
/// Many-to-many with StudyProgram — a program can belong to multiple
/// Studienfelder and appear equally in each (e.g. Wirtschaftsinformatik).
model StudyProgramCluster {
  id          String         @id @default(cuid())
  name        String         @db.VarChar(200)
  description String?        @db.Text
  institution Institution
  sortOrder   Int            @default(0)
  programs    StudyProgram[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([institution])
  @@index([sortOrder])
  @@map("study_program_clusters")
}

/// Study program offered by Uni or Hochschule
model StudyProgram {
  id          String                @id @default(cuid())
  name        String                @db.VarChar(200)
  institution Institution
  clusters    StudyProgramCluster[]
  links       StudyProgramLink[]
  events      EventStudyProgram[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([institution])
  @@map("study_programs")
}

/// External links for a study program (Fach, 2-Fächer-Bachelor, BEU, LBS …).
/// Replaces the former single StudyProgram.url field. Free-text label so the
/// admin can name each link; ordered by sortOrder.
model StudyProgramLink {
  id        String       @id @default(cuid())
  programId String
  program   StudyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  label     String       @db.VarChar(120)
  url       String       @db.VarChar(500)
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([programId])
  @@map("study_program_links")
}

/// Academic title (Dr., Prof., M.A., ...) — admin-managed vocabulary used by
/// the Melder and Dozent title fields. Values are still free-text on the
/// Melder/Lecturer records; this table only drives the suggestion dropdown.
model Title {
  id        String   @id @default(cuid())
  value     String   @unique @db.VarChar(50)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("titles")
}

/// Information market (Infomarkt) locations
model InformationMarket {
  id       String                   @id @default(cuid())
  name     String                   @db.VarChar(200)
  location String                   @db.VarChar(200)
  events   EventInformationMarket[]

  @@map("information_markets")
}

// =============================================================================
// Event Tables
// =============================================================================

/// A single HIT year. One row is always ACTIVE; others may be DRAFT or ARCHIVED.
model HitEdition {
  id                        String           @id @default(cuid())
  year                      Int              @unique
  hitDate                   DateTime
  submissionDeadline        DateTime?
  deadlineEnabled           Boolean          @default(true)
  status                    EditionStatus    @default(DRAFT)
  multiplikatorCafeEventId  String?
  multiplikatorCafeEvent    Event?           @relation("MultiplikatorCafeEvent", fields: [multiplikatorCafeEventId], references: [id], onDelete: SetNull)
  events                    Event[]
  userSchedules             UserSchedule[]
  sharedSchedules           SharedSchedule[]
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  @@index([status])
  @@map("hit_editions")
}

/// Main event entity - lectures, workshops, tours, info stands, etc.
model Event {
  id               String                   @id @default(cuid())
  title            String                   @db.VarChar(200)
  description      String?                  @db.Text
  eventType        EventType
  timeStart        DateTime?
  timeEnd          DateTime?
  locationDetails  Json?                    @db.JsonB
  /// CONFIRMED = building/room chosen; WISH = area + free-text preferences.
  locationMode     LocationMode             @default(CONFIRMED)
  /// Campus area when locationMode = WISH.
  locationWishArea CampusArea?
  roomRequest      String?                  @db.Text
  meetingPoint     String?                  @db.VarChar(500)
  additionalInfo   String?                  @db.Text
  photoUrl         String?                  @db.VarChar(500)
  institution      Institution
  isCrossProgram   Boolean                  @default(false)
  editionId        String
  edition          HitEdition               @relation(fields: [editionId], references: [id])
  reviewStatus     EventReviewStatus        @default(PUBLISHED)
  sourceEventId    String?
  sourceEvent      Event?                   @relation("EventCloneSource", fields: [sourceEventId], references: [id], onDelete: SetNull)
  clones           Event[]                  @relation("EventCloneSource")
  locationHint     String?
  melderId         String?
  melder           Melder?                  @relation(fields: [melderId], references: [id])
  buildingId       String?
  building         Building?                @relation(fields: [buildingId], references: [id])
  roomId           String?
  room             Room?                    @relation(fields: [roomId], references: [id])
  lecturers              Lecturer[]
  organizers             EventOrganizer[]
  studyPrograms          EventStudyProgram[]
  infoMarkets            EventInformationMarket[]
  scheduleItems          ScheduleItem[]
  asMultiplikatorCafeFor HitEdition[]             @relation("MultiplikatorCafeEvent")
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  // Single-column indexes
  @@index([eventType])
  @@index([institution])
  @@index([timeStart])
  @@index([createdAt])
  @@index([melderId])
  @@index([buildingId])
  @@index([roomId])
  // Compound indexes for common query patterns
  @@index([institution, eventType]) // Filtering by institution and type
  @@index([timeStart, timeEnd]) // Time range queries
  @@index([institution, timeStart]) // Events by institution sorted by time
  @@index([editionId])
  @@index([editionId, reviewStatus])
  @@index([sourceEventId])
  @@map("events")
}

/// Lecturer/speaker for an event
model Lecturer {
  id          String       @id @default(cuid())
  eventId     String
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  title       String?
  email       String?
  affiliation Affiliation?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([eventId])
  @@map("lecturers")
}

/// Event organizer contact information (internal use)
model EventOrganizer {
  id           String  @id @default(cuid())
  eventId      String
  event        Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  email        String  @db.VarChar(200)
  phone        String? @db.VarChar(50)
  internalOnly Boolean @default(true)

  @@index([eventId])
  @@map("event_organizers")
}

/// Junction table: Event to StudyProgram (many-to-many)
model EventStudyProgram {
  eventId        String
  studyProgramId String
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  studyProgram   StudyProgram @relation(fields: [studyProgramId], references: [id], onDelete: Cascade)

  @@id([eventId, studyProgramId])
  @@index([studyProgramId])
  @@map("event_study_programs")
}

/// Junction table: Event to InformationMarket (many-to-many)
model EventInformationMarket {
  eventId  String
  marketId String
  event    Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  market   InformationMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@id([eventId, marketId])
  @@index([marketId])
  @@map("event_information_markets")
}

// =============================================================================
// User & Schedule Tables
// =============================================================================

/// User account for authentication and authorization
model User {
  id           String         @id @default(cuid())
  email        String         @unique @db.VarChar(200)
  passwordHash String?        @db.VarChar(255)
  name         String?        @db.VarChar(200)
  role         UserRole       @default(PUBLIC)
  schedules    UserSchedule[]
  melder       Melder?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([email])
  @@index([role])
  @@map("users")
}

/// User's personal schedule/cart of events
model UserSchedule {
  id        String         @id @default(cuid())
  userId    String?
  user      User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?        @db.VarChar(100) // For anonymous users
  name      String         @default("My Schedule") @db.VarChar(100)
  items     ScheduleItem[]
  editionId String
  edition   HitEdition     @relation(fields: [editionId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([sessionId])
  @@index([userId])
  @@index([editionId])
  @@map("user_schedules")
}

/// Individual item in a user's schedule
model ScheduleItem {
  id         String       @id @default(cuid())
  scheduleId String
  schedule   UserSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  eventId    String
  event      Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  priority   Int          @default(1)
  notes      String?      @db.Text
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([scheduleId, eventId])
  @@index([eventId])
  @@map("schedule_items")
}

/// Shared schedule with short link code for anonymous schedule sharing
model SharedSchedule {
  id        String     @id @default(cuid())
  code      String     @unique @db.VarChar(10)
  eventIds  String[]
  editionId String
  edition   HitEdition @relation(fields: [editionId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([editionId])
  @@map("shared_schedules")
}

// =============================================================================
// Site Config & Submission Tables
// =============================================================================

/// Reporter/submitter profile linked to a User account
model Melder {
  id          String      @id @default(cuid())
  userId      String?     @unique
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  firstName   String
  lastName    String
  title       String?
  email       String
  phone       String?
  affiliation Affiliation
  // Single organizational-unit field, relabelled per affiliation in the UI
  // (Fakultät for Hochschule, Fachbereich for Universität, Institution for
  // Beide/Extern). Replaces the former fakultaet/fachbereich pair.
  organisationseinheit String?
  room                 String?
  // Used instead of room when affiliation is EXTERN (external organisers).
  adresse              String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  events      Event[]

  @@index([email])
  @@map("melders")
}

/// Campus building — single source of truth for locations, coordinates, and routing
model Building {
  id                 String      @id @default(cuid())
  slug               String      @unique @db.VarChar(50)
  name               String      @db.VarChar(200)
  shortName          String?     @db.VarChar(50)
  address            String?     @db.Text
  campus             String?     @db.VarChar(50)
  /// Owner institution. BOTH is used for shared buildings (Westerberg etc.)
  /// and drives the building filter in the event form.
  institution        Institution @default(BOTH)
  latitude           Float?
  longitude          Float?
  hasAccessibility   Boolean     @default(false)
  accessibilityNotes String?     @db.Text
  rooms              Room[]
  events             Event[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([campus])
  @@index([institution])
  @@map("buildings")
}

/// Room within a building
model Room {
  id         String   @id @default(cuid())
  name       String
  floor      String?
  buildingId String
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  events     Event[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([buildingId])
}

/// Admin-configured scheduled export
model ExportSchedule {
  id        String    @id @default(cuid())
  type      String // "html" (extensible for future export types)
  startDate DateTime
  frequency String // "daily" | "weekly"
  enabled   Boolean   @default(true)
  lastRun   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

/// Cached walking route between two buildings from Google Directions API
/// fromBuildingSlug/toBuildingSlug reference Building.slug for stable cache keys
model CachedRoute {
  id               String   @id @default(cuid())
  fromBuildingSlug String   @db.VarChar(50)
  toBuildingSlug   String   @db.VarChar(50)
  distanceMeters   Int
  durationSeconds  Int
  polyline         String   @db.Text
  waypoints        Json?    @db.JsonB
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([fromBuildingSlug, toBuildingSlug])
  @@map("cached_routes")
}

// =============================================================================
// Bus Tracking Tables
// =============================================================================

/// Shuttle bus for real-time GPS tracking
model ShuttleBus {
  id        String       @id @default(cuid())
  name      String // e.g. "Bus 1"
  number    Int          @unique
  token     String       @unique
  active    Boolean      @default(true)
  position  BusPosition?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

/// Latest GPS position for a shuttle bus (1:1 relation, overwritten on updates)
model BusPosition {
  id        String     @id @default(cuid())
  busId     String     @unique
  bus       ShuttleBus @relation(fields: [busId], references: [id], onDelete: Cascade)
  latitude  Float
  longitude Float
  heading   Float?
  speed     Float?
  updatedAt DateTime   @updatedAt
}
